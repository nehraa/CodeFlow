{
  "name": "@abhinav2203/codeflow-mcp",
  "version": "0.1.0",
  "description": "MCP server configuration and tool registry for CodeFlow blueprint operations.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./invoke": {
      "types": "./dist/invoke/index.d.ts",
      "default": "./dist/invoke/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "default": "./dist/tools/index.js"
    }
  },
  "bin": {
    "codeflow-mcp": "./dist/bin/cli.js"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsc --outDir dist --declaration --declarationMap && node scripts/wrap-cli.mjs",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@abhinav2203/codeflow-core": "workspace:*",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
